import "core:io"
import "lib:weasel"
page :: proc(w: io.Writer, p: ^Props) -> io.Error {
weasel.write_raw_string(w, "<div class=\"content\">") or_return
weasel.write_raw_string(w, "\n") or_return
weasel.write_raw_string(w, "<h1>") or_return
weasel.write_escaped_string(w, p.title) or_return
weasel.write_raw_string(w, "</h1>") or_return
weasel.write_raw_string(w, "\n") or_return
weasel.write_raw_string(w, "<p>") or_return
weasel.write_escaped_string(w, p.body) or_return
weasel.write_raw_string(w, "</p>") or_return
weasel.write_raw_string(w, "\n") or_return
if p.show_footer {
weasel.write_raw_string(w, "<footer>") or_return
weasel.write_escaped_string(w, p.footer) or_return
weasel.write_raw_string(w, "</footer>") or_return
}
weasel.write_raw_string(w, "\n") or_return
weasel.write_raw_string(w, "</div>") or_return

return nil
}


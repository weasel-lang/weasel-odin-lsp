import "core:io"
import "lib:weasel"

Task :: struct {
    name:        string,
    description: string,
    priority:    u32,
    due:         u64,
}

Task_Item_Props :: struct {
    task: ^Task,
}

item :: proc(w: io.Writer, p: Task_Item_Props) -> io.Error {
    weasel.write_raw_string(w, "<h2>") or_return
weasel.write_escaped_string(w, p.task.name) or_return
weasel.write_raw_string(w, " &ndash; P") or_return
weasel.write_escaped_string(w, p.task.prio) or_return
weasel.write_raw_string(w, "</h2>") or_return

    weasel.write_raw_string(w, "<p>") or_return
weasel.write_escaped_string(w, p.task.description) or_return
weasel.write_raw_string(w, "</p>") or_return

return nil
}


Task_List_Props :: struct {
    tasks: [dynamic]Task,
}

list :: proc(w: io.Writer, p: Task_List_Props) -> io.Error {
    weasel.write_raw_string(w, "<ul>") or_return
weasel.write_raw_string(w, "\n        ") or_return

            for task of p.tasks {

                item(w, Item_Props{task = task}) or_return

            }
weasel.write_raw_string(w, "\n    ") or_return
weasel.write_raw_string(w, "</ul>") or_return

return nil
}


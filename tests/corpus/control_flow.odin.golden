weasel.write_raw_string(w, "<ul>") or_return
for item in items {
weasel.write_raw_string(w, "<li>") or_return
weasel.write_escaped_string(w, item.name) or_return
weasel.write_raw_string(w, "</li>") or_return
}
weasel.write_raw_string(w, "</ul>") or_return

weasel.write_raw_string(w, "<div>") or_return
if show {
weasel.write_raw_string(w, "<span>") or_return
weasel.write_raw_string(w, "visible") or_return
weasel.write_raw_string(w, "</span>") or_return
}
weasel.write_raw_string(w, "</div>") or_return

weasel.write_raw_string(w, "<div>") or_return
switch kind {
case .A: weasel.write_raw_string(w, "<em>") or_return
weasel.write_raw_string(w, "Alpha") or_return
weasel.write_raw_string(w, "</em>") or_return
case .B: weasel.write_raw_string(w, "<em>") or_return
weasel.write_raw_string(w, "Beta") or_return
weasel.write_raw_string(w, "</em>") or_return
}
weasel.write_raw_string(w, "</div>") or_return


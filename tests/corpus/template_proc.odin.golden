import "core:io"
import "lib:weasel"
greet :: proc(w: io.Writer, name: string) -> io.Error {
weasel.write_raw_string(w, "<p>") or_return
weasel.write_raw_string(w, "Hello, ") or_return
weasel.write_escaped_string(w, name) or_return
weasel.write_raw_string(w, "!") or_return
weasel.write_raw_string(w, "</p>") or_return

return nil
}

